{
  "crons": [
    {
      "path": "/api/cron/review-requests",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/abandoned-cart",
      "schedule": "0 12 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)\\.txt",
      "destination": "/api/indexnow/key?key=$1"
    }
  ]
}
